{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "adf-data-1"
        },
        "AzureBlobStorage1_connectionString": {
            "type": "secureString",
            "metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
        },
        "SourceSqlDB_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'SourceSqlDB'"
        },
        "TargetSqlDB_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'TargetSqlDB'"
        },
        "AzureSqlDatabase1_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'AzureSqlDatabase1'"
        },
        "SourceSqlDB_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "bcbs1.database.windows.net"
        },
        "SourceSqlDB_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "ADF_TEST"
        },
        "SourceSqlDB_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "sumanadmin"
        },
        "TargetSqlDB_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "bcbs1.database.windows.net"
        },
        "TargetSqlDB_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "ADF_TEST"
        },
        "TargetSqlDB_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "sumanadmin"
        },
        "AzureKey_properties_typeProperties_baseUrl": {
            "type": "string",
            "defaultValue": "https://admin123.vault.azure.net/"
        },
        "AzureSqlDatabase1_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "bcbs1.database.windows.net"
        },
        "AzureSqlDatabase1_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "ADF_TEST"
        },
        "AzureSqlDatabase1_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "sumanadmin"
        },
        "containerUri": {
            "type": "string",
            "metadata": "URI to storage account containing linked ARM templates"
        },
        "containerSasToken": {
            "type": "string",
            "metadata": "Sas token to storage account containing linked ARM templates"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "adf-data-1_ArmTemplate_0",
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2024-03-01",
            "properties": {
                "mode": "incremental",
                "templateLink": {
                    "uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "factoryName": {
                        "value": "[parameters('factoryName')]"
                    },
                    "AzureBlobStorage1_connectionString": {
                        "value": "[parameters('AzureBlobStorage1_connectionString')]"
                    },
                    "SourceSqlDB_password": {
                        "value": "[parameters('SourceSqlDB_password')]"
                    },
                    "TargetSqlDB_password": {
                        "value": "[parameters('TargetSqlDB_password')]"
                    },
                    "AzureSqlDatabase1_password": {
                        "value": "[parameters('AzureSqlDatabase1_password')]"
                    },
                    "SourceSqlDB_properties_typeProperties_server": {
                        "value": "[parameters('SourceSqlDB_properties_typeProperties_server')]"
                    },
                    "SourceSqlDB_properties_typeProperties_database": {
                        "value": "[parameters('SourceSqlDB_properties_typeProperties_database')]"
                    },
                    "SourceSqlDB_properties_typeProperties_userName": {
                        "value": "[parameters('SourceSqlDB_properties_typeProperties_userName')]"
                    },
                    "TargetSqlDB_properties_typeProperties_server": {
                        "value": "[parameters('TargetSqlDB_properties_typeProperties_server')]"
                    },
                    "TargetSqlDB_properties_typeProperties_database": {
                        "value": "[parameters('TargetSqlDB_properties_typeProperties_database')]"
                    },
                    "TargetSqlDB_properties_typeProperties_userName": {
                        "value": "[parameters('TargetSqlDB_properties_typeProperties_userName')]"
                    },
                    "AzureKey_properties_typeProperties_baseUrl": {
                        "value": "[parameters('AzureKey_properties_typeProperties_baseUrl')]"
                    },
                    "AzureSqlDatabase1_properties_typeProperties_server": {
                        "value": "[parameters('AzureSqlDatabase1_properties_typeProperties_server')]"
                    },
                    "AzureSqlDatabase1_properties_typeProperties_database": {
                        "value": "[parameters('AzureSqlDatabase1_properties_typeProperties_database')]"
                    },
                    "AzureSqlDatabase1_properties_typeProperties_userName": {
                        "value": "[parameters('AzureSqlDatabase1_properties_typeProperties_userName')]"
                    }
                }
            },
            "dependsOn": []
        }
    ]
}